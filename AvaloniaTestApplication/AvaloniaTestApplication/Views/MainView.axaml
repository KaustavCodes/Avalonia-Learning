<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvaloniaTestApplication.ViewModels"
             mc:Ignorable="d" d:DesignWidth="430" d:DesignHeight="900"
             x:Class="AvaloniaTestApplication.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="#0D1117">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>

    <!-- ── Bottom-tab button base style ──────────────────────────────────── -->
    <!--
    Removes the default button chrome (background, border) so each tab
    button looks like a plain icon + label column.
    -->
    <Style Selector="Button.tab">
      <Setter Property="Background"            Value="Transparent"/>
      <Setter Property="BorderThickness"       Value="0"/>
      <Setter Property="HorizontalAlignment"   Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment"   Value="Center"/>
      <Setter Property="Padding"               Value="0"/>
      <Setter Property="Cursor"                Value="Hand"/>
    </Style>
    <Style Selector="Button.tab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.tab:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

  </UserControl.Styles>

  <!--
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  Shell layout – three rows:                                          ║
  ║    Row 0  → Top App Bar   (Auto height, expands with safe-area top)  ║
  ║    Row 1  → Page content  (fills remaining space)                    ║
  ║    Row 2  → Bottom Tab Bar (Auto height, expands with safe-area bot) ║
  ╚══════════════════════════════════════════════════════════════════════╝
  -->
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 0 – TOP APP BAR                                               -->
    <!--                                                                   -->
    <!--  x:Name="AppBar" is used by MainView.axaml.cs to adjust the top  -->
    <!--  Padding when the platform reports a safe-area inset (e.g.        -->
    <!--  iPhone notch / Dynamic Island).  On desktop the padding is 0.   -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            x:Name="AppBar"
            Padding="0,0,0,0">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#0D0A1A" Offset="0"/>
          <GradientStop Color="#111827" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>

      <!-- Bottom border line separating app bar from content -->
      <Border BorderBrush="#1C2128" BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="48,*,48"
              Margin="12,14,12,14">

          <!-- Left action placeholder (e.g. back / menu icon) -->
          <Border Grid.Column="0"
                  Width="36" Height="36"
                  CornerRadius="10"
                  Background="#161B22"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">
            <TextBlock Text="☰"
                       FontSize="16"
                       Foreground="#8B949E"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>

          <!-- Page title – updates automatically from MainViewModel -->
          <TextBlock Grid.Column="1"
                     Text="{Binding CurrentPageTitle}"
                     FontSize="17"
                     FontWeight="SemiBold"
                     Foreground="White"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>

          <!-- Right action placeholder (e.g. notifications) -->
          <Border Grid.Column="2"
                  Width="36" Height="36"
                  CornerRadius="10"
                  Background="#161B22"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
            <TextBlock Text="🔔"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>

        </Grid>
      </Border>
    </Border>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 1 – PAGE CONTENT                                              -->
    <!--                                                                   -->
    <!--  TransitioningContentControl resolves each ViewModel to its View  -->
    <!--  automatically via the ViewLocator registered in App.axaml.       -->
    <!--  PageSlide gives a horizontal swipe feel between tabs.            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <TransitioningContentControl Grid.Row="1"
                                 Content="{Binding CurrentPage}">
      <TransitioningContentControl.PageTransition>
        <PageSlide Duration="0:0:0.25" Orientation="Horizontal"/>
      </TransitioningContentControl.PageTransition>
    </TransitioningContentControl>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- ROW 2 – BOTTOM NAVIGATION BAR                                     -->
    <!--                                                                   -->
    <!--  x:Name="BottomBar" is used by MainView.axaml.cs to add bottom   -->
    <!--  Padding equal to the safe-area inset (home indicator on iPhone). -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            x:Name="BottomBar"
            Background="#0D0A1A"
            BorderBrush="#1C2128"
            BorderThickness="0,1,0,0"
            Padding="0,0,0,0">

      <Grid ColumnDefinitions="*,*,*" Height="62">

        <!-- ── Tab 1: Home ── -->
        <Button Grid.Column="0"
                Classes="tab"
                Command="{Binding SelectHomeCommand}">
          <StackPanel Spacing="3" HorizontalAlignment="Center">
            <TextBlock Text="⌂"
                       FontSize="22"
                       Foreground="{Binding HomeTabForeground}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Home"
                       FontSize="10"
                       Foreground="{Binding HomeTabForeground}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Stats"
                       FontSize="10"
                       Foreground="{Binding StatsTabForeground}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- ── Tab 3: Profile ── -->
        <Button Grid.Column="2"
                Classes="tab"
                Command="{Binding SelectProfileCommand}">
          <StackPanel Spacing="3" HorizontalAlignment="Center">
            <TextBlock Text="👤"
                       FontSize="22"
                       Foreground="{Binding ProfileTabForeground}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Profile"
                       FontSize="10"
                       Foreground="{Binding ProfileTabForeground}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

      </Grid>
    </Border>

  </Grid>

</UserControl>

